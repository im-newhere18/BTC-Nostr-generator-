  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #F7931A;
      --dark: #0a0a0f;
      --card: #111118;
      --border: #1e1e2e;
      --green: #00e5a0;
      --red: #ff4d6d;
      --muted: #6b6b8a;
      --text: #e8e8f0;
      --subtext: #d0d0e8;
    }
    body {
      background: var(--dark);
      color: var(--text);
      font-family: 'Courier New', monospace;
      min-height: 100vh;
      padding: 28px 16px 60px;
    }
    .wrap { max-width: 620px; margin: 0 auto; }
    .header { margin-bottom: 32px; }
    .header-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .btc-logo {
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--orange); display: flex; align-items: center;
      justify-content: center; font-size: 20px; font-weight: 900;
      color: #000; flex-shrink: 0; box-shadow: 0 0 24px #F7931A66;
    }
    .header-title { font-size: 18px; font-weight: 700; letter-spacing: -0.5px; color: #fff; }
    .header-sub { font-size: 10px; color: var(--muted); letter-spacing: 2.5px; text-transform: uppercase; margin-top: 3px; }
    .header-line { height: 1px; background: linear-gradient(90deg, #F7931A55, transparent); }
    .section { margin-bottom: 24px; }
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 2px; color: var(--orange); text-transform: uppercase; margin-bottom: 10px; }
    .field-label { font-size: 11px; color: var(--muted); margin-bottom: 5px; letter-spacing: 1px; }
    input[type="text"], input[type="password"] {
      width: 100%; padding: 10px 14px;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text);
      font-size: 13px; font-family: 'Courier New', monospace;
      outline: none; transition: border-color 0.2s; -webkit-appearance: none;
    }
    input[type="text"]:focus, input[type="password"]:focus { border-color: var(--orange); }
    input::placeholder { color: var(--muted); }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .etf-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; align-items: center; margin-bottom: 9px; }
    .etf-day { font-size: 12px; color: var(--muted); }
    .badge { margin-top: 10px; padding: 9px 14px; border-radius: 8px; font-size: 13px; display: flex; align-items: center; gap: 8px; }
    .badge.green { background: #00e5a012; border: 1px solid #00e5a044; color: var(--green); }
    .badge.red { background: #ff4d6d12; border: 1px solid #ff4d6d44; color: var(--red); }
    .badge.hidden { display: none; }
    .key-wrap { position: relative; }
    .key-wrap input { padding-right: 60px; }
    .btn-toggle {
      position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: var(--muted);
      cursor: pointer; font-size: 11px; font-family: 'Courier New', monospace;
      letter-spacing: 1px;
    }
    .key-hint { margin-top: 8px; font-size: 11px; color: var(--muted); }
    .key-hint a { color: var(--orange); text-decoration: none; }
    .btn-generate {
      width: 100%; padding: 15px 0;
      background: var(--orange); color: #000;
      border: none; border-radius: 10px;
      font-size: 13px; font-weight: 700; font-family: 'Courier New', monospace;
      letter-spacing: 1.5px; cursor: pointer;
      box-shadow: 0 0 30px #F7931A22, 0 0 60px #F7931A0a;
      transition: all 0.2s;
    }
    .btn-generate:disabled { background: var(--border); color: var(--muted); box-shadow: none; cursor: default; }
    .hint { text-align: center; margin-top: 14px; font-size: 11px; color: var(--muted); }
    .error-box {
      color: var(--red); font-size: 13px; margin-bottom: 16px;
      padding: 10px 14px; background: #ff4d6d12;
      border-radius: 8px; border: 1px solid #ff4d6d33; display: none;
    }
    #output-section { display: none; }
    .post-box {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 20px;
      font-size: 14px; line-height: 1.8; color: var(--subtext);
      white-space: pre-wrap; word-break: break-word;
    }
    .btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
    .btn-copy {
      padding: 14px 0; background: var(--card); color: #fff;
      border: 1px solid var(--border); border-radius: 10px;
      font-size: 13px; font-weight: 700; font-family: 'Courier New', monospace;
      cursor: pointer; letter-spacing: 0.5px; transition: all 0.2s;
    }
    .btn-copy.copied { background: #00e5a020; color: var(--green); border-color: var(--green); }
    .btn-new {
      padding: 14px 0; background: var(--orange); color: #000;
      border: none; border-radius: 10px;
      font-size: 13px; font-weight: 700; font-family: 'Courier New', monospace;
      cursor: pointer; letter-spacing: 0.5px; box-shadow: 0 0 30px #F7931A22;
    }
    .output-hint { text-align: center; margin-top: 16px; font-size: 11px; color: var(--muted); }
  </style>
</head>

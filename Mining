<script>
  function parseNum(val) {
    return parseFloat((val || "").replace(/[^0-9.-]/g, ""));
  }

function getKey() {
return document.getElementById(“apiKey”).value.trim() ||
localStorage.getItem(“btc_nostr_api_key”) || “”;
}

function saveKey() {
const key = document.getElementById(“apiKey”).value.trim();
const badge = document.getElementById(“keyBadge”);
if (key.startsWith(“sk-ant-”)) {
localStorage.setItem(“btc_nostr_api_key”, key);
badge.className = “badge green”;
badge.innerHTML = “✓ API key saved”;
} else if (key.length > 0) {
badge.className = “badge red”;
badge.innerHTML = “Key should start with sk-ant-…”;
} else {
badge.className = “badge hidden”;
}
}

function toggleKey() {
const input = document.getElementById(“apiKey”);
const btn = document.querySelector(”.btn-toggle”);
if (input.type === “password”) { input.type = “text”; btn.textContent = “HIDE”; }
else { input.type = “password”; btn.textContent = “SHOW”; }
}

function updateCalc() {
const open = parseNum(document.getElementById(“btcOpen”).value);
const close = parseNum(document.getElementById(“btcClose”).value);
const badge = document.getElementById(“pctBadge”);
if (open && close) {
const pct = (((close - open) / open) * 100).toFixed(2);
const up = parseFloat(pct) >= 0;
badge.className = “badge “ + (up ? “green” : “red”);
badge.innerHTML = `<span>${up ? "▲" : "▼"}</span><span>Weekly change: <strong>${up ? "+" : ""}${pct}%</strong></span>`;
} else {
badge.className = “badge hidden”;
}
}

function updateETFTotal() {
const inputs = document.querySelectorAll(”.etf-input”);
let total = 0;
inputs.forEach(inp => { const n = parseNum(inp.value); if (!isNaN(n)) total += n; });
const badge = document.getElementById(“etfBadge”);
if (total !== 0) {
const up = total >= 0;
badge.className = “badge “ + (up ? “green” : “red”);
badge.innerHTML = `Weekly ETF Total: <strong>${up ? "+" : ""}${total.toFixed(0)}M USD</strong>`;
} else {
badge.className = “badge hidden”;
}
}

function getETFSummary() {
const days = [“Monday”,“Tuesday”,“Wednesday”,“Thursday”,“Friday”];
const inputs = document.querySelectorAll(”.etf-input”);
let total = 0;
const lines = [];
inputs.forEach((inp, i) => {
const n = parseNum(inp.value);
if (!isNaN(n)) total += n;
lines.push(`${days[i]}: ${inp.value || "N/A"}`);
});
return { summary: lines.join(”, “), total };
}

function showError(msg) {
const box = document.getElementById(“errorBox”);
box.textContent = msg; box.style.display = “block”;
}

function hideError() {
document.getElementById(“errorBox”).style.display = “none”;
}

async function handleGenerate() {
hideError();
const apiKey = getKey();
const dateRange = document.getElementById(“dateRange”).value.trim();
const btcOpen = document.getElementById(“btcOpen”).value.trim();
const btcClose = document.getElementById(“btcClose”).value.trim();
const open = parseNum(btcOpen);
const close = parseNum(btcClose);

```
if (!apiKey || !apiKey.startsWith("sk-ant-")) {
  showError("Please enter a valid Anthropic API key (starts with sk-ant-).");
  return;
}
if (!dateRange || !open || !close) {
  showError("Please fill in the date range, open price, and close price.");
  return;
}

const pct = (((close - open) / open) * 100).toFixed(2);
const { summary: etfSummary, total: weeklyTotal } = getETFSummary();
const isUp = parseFloat(pct) >= 0;

const btn = document.getElementById("generateBtn");
btn.disabled = true;
btn.textContent = "⚡ GENERATING YOUR POST...";

const prompt = `You are a Bitcoin educator writing a short, bold, punchy weekly Nostr post under 150 words. Use this EXACT template structure, filling in the bracketed sections:
```

⚡ BITCOIN WEEKLY RECAP ⚡
${dateRange}

━━━━━━━━━━━━━━━━━
₿ PRICE ACTION
━━━━━━━━━━━━━━━━━
Open: $${btcOpen}
Close: $${btcClose}
Weekly: ${pct}% ${isUp ? “📈” : “📉”}

[Write exactly 1 sharp, educational sentence about what this price move signals to the market]

━━━━━━━━━━━━━━━━━
🏦 ETF FLOWS
━━━━━━━━━━━━━━━━━
Weekly Net: ${weeklyTotal >= 0 ? “+” : “”}${weeklyTotal.toFixed(0)}M ${weeklyTotal >= 0 ? “🟢” : “🔴”}

[Write exactly 1 sharp, educational sentence about what this institutional flow signals]

━━━━━━━━━━━━━━━━━

[Write 1 punchy question or call-to-action to engage followers]

#Bitcoin #BTC #Nostr

📊 Data: Farside Investors
⚠️ Not financial advice

Only return the post itself. No preamble, no explanation. Keep it under 150 words total. Make it feel human and bold, not robotic.`;

```
try {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": apiKey,
      "anthropic-version": "2023-06-01",
      "anthropic-dangerous-direct-browser-access": "true",
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-6",
      max_tokens: 1000,
      messages: [{ role: "user", content: prompt }],
    }),
  });

  const rawText = await response.text();
  let data;
  try { data = JSON.parse(rawText); }
  catch { throw new Error("Could not parse response: " + rawText.slice(0, 100)); }

  if (!response.ok) {
    throw new Error("API " + response.status + ": " + (data?.error?.message || response.statusText));
  }

  let text = "";
  if (Array.isArray(data.content)) {
    text = data.content.map(b => b.text || "").join("").trim();
  } else if (typeof data.content === "string") {
    text = data.content.trim();
  }
  if (!text) throw new Error("Empty response. Raw: " + rawText.slice(0, 200));

  document.getElementById("postBox").textContent = text;
  document.getElementById("input-section").style.display = "none";
  document.getElementById("output-section").style.display = "block";

} catch (e) {
  showError("Error: " + e.message);
} finally {
  btn.disabled = false;
  btn.textContent = "⚡ GENERATE NOSTR POST";
}
```

}

function handleCopy() {
const text = document.getElementById(“postBox”).textContent;
navigator.clipboard.writeText(text).then(() => {
const btn = document.getElementById(“copyBtn”);
btn.textContent = “✓ COPIED!”;
btn.classList.add(“copied”);
setTimeout(() => { btn.textContent = “📋 COPY POST”; btn.classList.remove(“copied”); }, 2000);
});
}

function handleNewWeek() {
document.getElementById(“input-section”).style.display = “block”;
document.getElementById(“output-section”).style.display = “none”;
document.getElementById(“dateRange”).value = “”;
document.getElementById(“btcOpen”).value = “”;
document.getElementById(“btcClose”).value = “”;
document.querySelectorAll(”.etf-input”).forEach(i => i.value = “”);
document.getElementById(“pctBadge”).className = “badge hidden”;
document.getElementById(“etfBadge”).className = “badge hidden”;
hideError();
}

// Load saved API key on page load
window.addEventListener(“load”, function() {
const saved = localStorage.getItem(“btc_nostr_api_key”);
if (saved) {
document.getElementById(“apiKey”).value = saved;
const badge = document.getElementById(“keyBadge”);
badge.className = “badge green”;
badge.innerHTML = “✓ API key saved”;
}
});
</script>

